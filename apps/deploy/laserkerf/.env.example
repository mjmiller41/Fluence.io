# Copy to apps/deploy/laserkerf/.env on the box. Git-ignored; never commit the real one.

# --- Phase A (static PWA) ---
TAG=local                 # image tag to build/deploy, e.g. v0.1.0 or a git sha

# --- Phase B (licensing/accounts API — NOT built yet; see /DEPLOY.md "Phase B") ---
# Shared Postgres engine, dedicated laserkerf DB/role (no cross-DB access to laserready):
# DATABASE_URL=postgres://laserkerf:CHANGE_ME_STRONG@postgres:5432/laserkerf
# License signing PRIVATE key — the sensitive one; back it up out of band, loss is unrecoverable:
# LICENSE_SIGNING_KEY=
# Stripe webhook secret (license issuance on checkout.session.completed):
# STRIPE_WEBHOOK_SECRET=whsec_...
